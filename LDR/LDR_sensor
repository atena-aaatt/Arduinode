int sensor =A0;
int led=13;
void setup()
{
 pinMode (led,OUTPUT);
 Serial.begin(9600);
}

void loop()
{
 int lightLevel=analogRead(sensor);
  Serial.print("Lichtwert:");
  Serial.println(lightLevel);
  
  if(lightLevel<500){
    digitalWrite(led,HIGH);
  }
  else{
    digitalWrite(led,LOW);
  }
  delay(100);
}